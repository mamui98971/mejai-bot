{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@config/*": [
        "./server/config/*"
      ],
      "@services/*": [
        "./server/services/*"
      ],
      "@handlers/*": [
        "./server/handlers/*"
      ],
      "@middleware/*": [
        "./server/middleware/*"
      ],
      "@router/*": [
        "./server/router/*"
      ],
      "@types/*": [
        "./server/types/*"
      ],
      "@utils/*": [
        "./server/utils/*"
      ]
    }
  },
  "include": [
    "src",
    "server",
    "api"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "liff"
  ]
}