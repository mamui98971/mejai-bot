{
  "name": "project-mejai",
  "version": "1.0.0",
  "description": "AI-driven LINE Chatbot - Personal assistant, financial controller, fitness coach, and anime roleplay companion",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "npm --prefix liff run lint",
    "build": "npm run typecheck && npm --prefix liff run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:menu": "tsx src/scripts/setup-rich-menu.ts"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "omise": "^1.1.0",
    "openai": "^4.60.0",
    "sharp": "^0.35.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
