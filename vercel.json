{
  "version": 2,
  "buildCommand": "cd liff && npm install && npm run build && cd .. && rm -rf public && mv liff/dist public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/health",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/notify",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/reset-daily-limits",
      "schedule": "0 17 * * *"
    }
  ]
}
