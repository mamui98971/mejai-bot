{
  "version": 2,
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noai, noimageai"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/notify",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/reset-daily-limits",
      "schedule": "0 17 * * *"
    }
  ]
}